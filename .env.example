# ──────────────────────────────────────────────────────────────
# העתק קובץ זה ל-.env.local ומלא את הערכים
# ──────────────────────────────────────────────────────────────

# חובה — אימות
NEXTAUTH_SECRET=replace-with-any-long-random-string
NEXTAUTH_URL=http://localhost:3000

# חובה — פרטי המשתמש היחיד
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-password

# ──────────────────────────────────────────────────────────────
# Vercel KV — נדרש רק בפרודקשן (Vercel ימלא אוטומטית)
# בפיתוח מקומי: אם משתנים אלו חסרים, האפליקציה שומרת ב-data/db.json
# ──────────────────────────────────────────────────────────────
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
